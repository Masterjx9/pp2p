#!/bin/sh

set -eu

if [ "$#" -lt 2 ]; then
  echo "Usage: $0 <output-archive> <input-archive> [<input-archive> ...]" >&2
  exit 2
fi

abspath() {
  case "$1" in
    /*) printf '%s\n' "$1" ;;
    *) printf '%s/%s\n' "$(pwd)" "$1" ;;
  esac
}

apple_symdef_fix() {
  # On modern macOS/iOS, strip __.SYMDEF* before re-archiving.
  if [ "$(uname -s)" = "Darwin" ]; then
    find . -name "__.SYMDEF*" -delete
  fi
}

TARGET="$(abspath "$1")"
shift

if command -v mktemp >/dev/null 2>&1; then
  WORKDIR="$(mktemp -d "${TMPDIR:-/tmp}/combine_libs.XXXXXX")"
else
  WORKDIR="${TMPDIR:-/tmp}/combine_libs.$$.$(date +%s)"
  mkdir -p "$WORKDIR"
fi

cleanup() {
  rm -rf "$WORKDIR"
}
trap cleanup EXIT INT TERM

for input in "$@"; do
  INPUT_ABS="$(abspath "$input")"
  if [ ! -f "$INPUT_ABS" ]; then
    echo "combine_libs: missing input archive: $input" >&2
    exit 1
  fi

  UNPACK_DIR="$WORKDIR/$(basename "$input")"
  mkdir -p "$UNPACK_DIR"
  (
    cd "$UNPACK_DIR"
    "${AR:-ar}" x "$INPUT_ABS"
  )
done

cd "$WORKDIR" >/dev/null
apple_symdef_fix

# Keep the default "u" in ARFLAGS for compatibility with upstream makefiles.
# GNU ar prints a warning that "u" is ignored with deterministic mode, but
# still succeeds.
"${AR:-ar}" "${ARFLAGS:-cru}" library.tmp.a ./*/*
"${RANLIB:-ranlib}" library.tmp.a
mv -f library.tmp.a "$TARGET"
